# ─── Gemini API key ───────────────────────────────────────────────────────────
# Local dev: set directly here.
# Production (Lambda): leave unset — key is fetched from AWS Secrets Manager
#   at secret path "gemini/api_key" with JSON field "key".
#   Create via: aws secretsmanager create-secret --name gemini/api_key \
#     --secret-string '{"key":"YOUR_GEMINI_API_KEY"}'
GEMINI_API_KEY=your_gemini_api_key_here

# AWS region
AWS_REGION=us-east-1

# SNS topic ARN — set this for local dev testing of SNS publishing.
# In production (Lambda) the topic ARN is injected automatically by SAM.
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:YOUR_ACCOUNT_ID:routineweave-notifications-production

# ─── Optional (not needed when running on Lambda with IAM role) ────────────────
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ─── S3 Task Store (required in production, optional for local dev) ───────────
# TASKS_BUCKET=routineweave-tasks-production-YOUR_ACCOUNT_ID
# TASKS_S3_PREFIX=tasks/

# ─── Application Settings ─────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# Directory containing task JSON files for local development (ignored in Lambda)
TASKS_DIR=./tasks

# Retry configuration
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000
