{
  "name": "routineweave",
  "version": "1.0.0",
  "description": "AI-powered scheduled execution engine with Gemini and AWS SNS",
  "main": "dist/lambda.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/local.js",
    "dev": "ts-node src/local.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "package": "npm run clean && npm run build && npm prune --production"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.600.0",
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/client-secrets-manager": "^3.1033.0",
    "@aws-sdk/client-sns": "^3.600.0",
    "@google/genai": "^1.50.1",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.x"
  }
}
